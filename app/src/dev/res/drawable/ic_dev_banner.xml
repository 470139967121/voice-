        android:gravity="top|end"
        android:top="20dp"
        android:end="20dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFF0000" />
            <size android:width="36dp" android:height="14dp" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>
