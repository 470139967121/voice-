{
  "name": "shytalk-api",
  "version": "2.0.0",
  "description": "ShyTalk API server (Express.js + Firebase Admin SDK)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "local": "node --env-file=.env.local src/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --verbose",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint --fix . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@apple/app-store-server-library": "^3.1.0",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "archiver": "^8.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.9.0",
    "helmet": "^8.2.0",
    "livekit-server-sdk": "^2.15.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.8",
    "otplib": "^13.4.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "fast-xml-parser": ">=5.7.2",
    "@tootallnate/once": ">=3.0.1",
    "uuid": ">=14.0.0"
  }
}
