#!/usr/bin/env sh

# SHY-0066: removed the pre-commit call to `scripts/generate-roadmap-json.js`
# for the same reason as the matching pre-push removal: the deprecated
# pre-SHY-0038 generator silently rewrites `public/roadmap-data.json` to an
# obsolete shape (no `_meta`, no `items[]`) on every commit. SHY-0038's
# `scripts/sync-shy-to-roadmap-data.mjs` is now the canonical regenerator,
# running in CI via `.github/workflows/sync-roadmap-data.yml` under
# App-signed commits gated by ruleset 12613584 bypass_actors. Operator-
# authorised in SHY-0066 AskUserQuestion at 2026-06-09 ~11:30 BST (same
# scope as the pre-push fix — same deprecated script, sibling hook).

# Secret scanning — block commits containing API keys, tokens, or credentials
# Only scan ADDED lines (starting with +) to avoid false positives on removals
SECRETS_FOUND=$(git diff --cached --diff-filter=d -U0 | grep '^+' | grep -v '^+++' | grep -iE '(AIzaSy[A-Za-z0-9_-]{33}|sk-[A-Za-z0-9]{48}|ghp_[A-Za-z0-9]{36}|AKIA[0-9A-Z]{16}|-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----|password\s*[:=]\s*["\x27][^"\x27]{8,})' || true)
if [ -n "$SECRETS_FOUND" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════╗"
  echo "║  SECRET DETECTED IN STAGED FILES — BLOCKED   ║"
  echo "╚══════════════════════════════════════════════╝"
  echo ""
  echo "$SECRETS_FOUND"
  echo ""
  echo "Remove the secret and use environment variables instead."
  exit 1
fi

# Environment isolation — block environment URLs without localhost fallback
# Lines containing shytalk.shyden.co.uk MUST also contain "localhost" on the same line
# This ensures every URL resolution handles local development
UNSAFE_URLS=$(git diff --cached --diff-filter=d -U0 \
  -- '*.html' '*.js' '*.ts' '*.mjs' '*.cjs' \
  ':(exclude)functions/_lib/lockdown.js' \
  ':(exclude)functions/_middleware.js' \
  ':(exclude)express-api/src/middleware/no-index.js' \
  ':(exclude)express-api/tests/**' \
  ':(exclude)tests/web/**' \
  | grep '^+' | grep -v '^+++' | grep -v '^\+\s*//' | grep -E "shytalk\.shyden\.co\.uk" | grep -v "localhost" || true)
if [ -n "$UNSAFE_URLS" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════╗"
  echo "║  ENV URL WITHOUT LOCALHOST FALLBACK — BLOCKED        ║"
  echo "╚══════════════════════════════════════════════════════╝"
  echo ""
  echo "$UNSAFE_URLS"
  echo ""
  echo "Every line with a shytalk URL must also handle localhost."
  echo "Use env vars or: localhost ? local : dev ? dev-url : prod-url"
  exit 1
fi

npx lint-staged
