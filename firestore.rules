rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      // Owner can update non-economy fields
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['shyCoins', 'shyBeans', 'isSuperShy', 'superShyExpiry', 'superShyTier',
                     'gcsLastDeductionAt', 'isSuspended', 'suspensionReason', 'suspensionExpiry',
                     'suspensionEndDate', 'userType']);

      // Backpack — read own, write only via Worker API (economy safety)
      match /backpack/{giftId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Gift Wall — auth read, write only via Worker API
      match /giftWall/{giftId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // Transactions — owner or admin read, write only via Worker API
      match /transactions/{txId} {
        allow read: if request.auth != null
                    && (request.auth.uid == uid || request.auth.token.admin == true);
        allow write: if false;
      }

      // Stalkers (profile visitors) — auth read own, any auth user can write visitor entry
      match /stalkers/{visitorId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null;
      }
    }

    // ── Rooms ──────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      // Create: any authenticated user
      allow create: if request.auth != null;
      // Update: owner or current participant
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.ownerId
            || request.auth.uid in resource.data.participantIds);
      // Delete: only owner
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;

      // Room chat messages
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        // Edit/delete own messages only
        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.senderId;
      }

      // Seat requests within a room
      match /seatRequests/{requestId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
      }
    }

    // ── Conversations ──────────────────────────────────────────────
    match /conversations/{conversationId} {
      // get: allow on non-existent docs (existence check before create)
      allow get: if request.auth != null;
      // list: only participants can query conversations
      allow list: if request.auth != null
                  && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        // Edit/recall own messages
        allow update, delete: if request.auth != null
          && (request.auth.uid == resource.data.senderId
              || request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.adminIds
              || request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.modIds);

        // Message edit history
        match /edits/{editId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
        }
      }

      // User-specific conversation settings (renamed from settings to userSettings)
      match /userSettings/{userId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
        allow update: if request.auth != null && request.auth.uid == userId;
      }

      // Legacy settings path — keep for backwards compat during migration
      match /settings/{userId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
        allow update: if request.auth != null && request.auth.uid == userId;
      }

      match /mutes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      match /mod_log/{logId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }

    // ── App config — auth read, server write only ──────────────────
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Device bindings — auth read/write ──────────────────────────
    match /deviceBindings/{deviceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Counters (unique ID generation) — server only ──────────────
    match /counters/{counterId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Gift catalog — auth read, server write only ────────────────
    match /gifts/{giftId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Gift rankings — auth read, server write only ───────────────
    match /giftRankings/{giftId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Broadcasts — auth read, server write only ──────────────────
    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Coin packages — auth read, server write only ───────────────
    match /coinPackages/{packageId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Reports — auth create, server manage ───────────────────────
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
    }

    // ── Archived reports — server only ─────────────────────────────
    match /reportsArchive/{reportId} {
      allow read, write: if false;
    }

    // ── Suspension appeals ─────────────────────────────────────────
    match /suspensionAppeals/{appealId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // ── Fun facts — auth read, server write ────────────────────────
    match /funFacts/{factId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Banners — auth read, server write only ─────────────────────
    match /banners/{bannerId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Admin tokens — server only ─────────────────────────────────
    match /adminTokens/{tokenId} {
      allow read, write: if false;
    }

    // ── Admin audit log — server only ──────────────────────────────
    match /adminAuditLog/{logId} {
      allow read, write: if false;
    }

    // ── Report locks — server only ─────────────────────────────────
    match /reportLocks/{lockId} {
      allow read, write: if false;
    }
  }
}
