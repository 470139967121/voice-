rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      // Owner can update non-economy fields
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['shyCoins', 'shyBeans', 'isSuperShy', 'superShyExpiry', 'superShyTier',
                     'gcsLastDeductionAt', 'isSuspended', 'suspensionReason',
                     'suspensionEndDate', 'userType']);

      // Backpack — read own, write only via Worker API (economy safety)
      match /backpack/{giftId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Gift Wall — auth read, write only via Worker API
      match /giftWall/{giftId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // Transactions — owner or admin read, write only via Worker API
      match /transactions/{txId} {
        allow read: if request.auth != null
                    && (request.auth.uid == uid || request.auth.token.admin == true);
        allow write: if false;
      }

      // Stalkers (profile visitors) — owner reads, visitors can only create their own entry
      match /stalkers/{visitorId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == visitorId;
        allow update, delete: if false;
      }
    }

    // ── Rooms ──────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      // Create: any authenticated user
      allow create: if request.auth != null;
      // Update: owner or current participant
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.ownerId
            || request.auth.uid in resource.data.participantIds);
      // Delete: only owner
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;

      // Room chat messages
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        // Edit/delete own messages only
        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.senderId;
      }

      // Seat requests within a room — any auth can read/create, only owner can approve/reject
      match /seatRequests/{requestId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId;
      }
    }

    // ── Conversations ──────────────────────────────────────────────
    match /conversations/{conversationId} {
      // get: allow on non-existent docs (existence check before create)
      allow get: if request.auth != null;
      // list: only participants can query conversations
      allow list: if request.auth != null
                  && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        // Edit/recall own messages, or conversation admin/mod
        allow update, delete: if request.auth != null
          && (request.auth.uid == resource.data.senderId
              || request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.adminIds
              || request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.modIds);

        // Message edit history — participants only
        match /edits/{editId} {
          allow read: if request.auth != null
            && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
          allow create: if request.auth != null
            && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
      }

      // User-specific conversation settings — own settings only
      match /userSettings/{userId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
      }

      // Legacy settings path — keep for backwards compat during migration
      match /settings/{userId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
      }

      // Mutes — participants can read, only own mute entry writable
      match /mutes/{userId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Mod log — participants can read, admins/mods can create
      match /mod_log/{logId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if request.auth != null
          && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.adminIds
              || request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.modIds);
      }
    }

    // ── App config — auth read, server write only ──────────────────
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Device bindings — own read, create own, no hijacking others ─
    match /deviceBindings/{deviceId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── Counters (unique ID generation) — server only ──────────────
    match /counters/{counterId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Gift catalog — auth read, server write only ────────────────
    match /gifts/{giftId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Gift rankings — auth read, server write only ───────────────
    match /giftRankings/{giftId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Broadcasts — auth read, server write only ──────────────────
    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Coin packages — auth read, server write only ───────────────
    match /coinPackages/{packageId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Reports — server manages all access (Admin SDK bypasses rules)
    match /reports/{reportId} {
      allow read: if false;
      allow create: if false;
      allow update: if false;
    }

    // ── Archived reports — server only ─────────────────────────────
    match /reportsArchive/{reportId} {
      allow read, write: if false;
    }

    // ── Suspension appeals ─────────────────────────────────────────
    match /suspensionAppeals/{appealId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // ── Fun facts — auth read, server write ────────────────────────
    match /funFacts/{factId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Banners — auth read, server write only ─────────────────────
    match /banners/{bannerId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Admin tokens — server only ─────────────────────────────────
    match /adminTokens/{tokenId} {
      allow read, write: if false;
    }

    // ── Admin audit log — server only ──────────────────────────────
    match /adminAuditLog/{logId} {
      allow read, write: if false;
    }

    // ── Report locks — server only ─────────────────────────────────
    match /reportLocks/{lockId} {
      allow read, write: if false;
    }

    // ── Logs — server writes, admin reads ────────────────────────
    match /logs/{logId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── Log config — any auth read (mobile needs level config), server write ─
    match /logConfig/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Log stats — any auth read, server write ─────────────────
    match /logStats/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Device bans — admin read, server write ──────────────────
    match /deviceBans/{deviceId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── Network bans — admin read, server write ─────────────────
    match /networkBans/{banId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── Alerts — admin read, server write ────────────────────────
    match /alerts/{alertId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── Alert config — admin read, server write ─────────────────
    match /alertConfig/{docId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }
  }
}
