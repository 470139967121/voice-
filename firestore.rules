rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      // Allow any authed user to add/remove themselves from another user's followerIds
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerIds']);

      // Backpack — read own, write only via Cloud Functions
      match /backpack/{giftId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Gift Wall — auth read, write only via Cloud Functions
      match /giftWall/{giftId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // Transactions — owner or admin read, write only via Cloud Functions
      match /transactions/{txId} {
        allow read: if request.auth != null
                    && (request.auth.uid == uid || request.auth.token.admin == true);
        allow write: if false;
      }

      // Stalkers (profile visitors) — auth read own, write visitor entry
      match /stalkers/{visitorId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null;
      }
    }

    // Rooms
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      // Room chat messages
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      // Seat requests within a room
      match /seatRequests/{requestId} {
        allow read, write: if request.auth != null;
      }
    }

    // Conversations
    match /conversations/{conversationId} {
      // get: allow on non-existent docs (existence check before create)
      allow get: if request.auth != null;
      // list: only participants can query conversations
      allow list: if request.auth != null
                  && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;

        // Message edit history
        match /edits/{editId} {
          allow read: if request.auth != null;
          allow write: if request.auth != null;
        }
      }
      match /settings/{userId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // create: any participant can init default settings for others during group creation
        allow create: if request.auth != null;
        allow update: if request.auth != null && request.auth.uid == userId;
      }
      match /mutes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
      match /mod_log/{logId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }

    // App config — auth read, server write only
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Device bindings — auth read/write for device binding checks
    match /deviceBindings/{deviceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Counters (unique ID generation)
    match /counters/{counterId} {
      allow read, write: if request.auth != null;
    }

    // Gift catalog — auth read, admin write only
    match /gifts/{giftId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Gift rankings — auth read, server write only
    match /giftRankings/{giftId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Broadcasts — auth read, server write only
    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Coin packages — auth read, admin write only
    match /coinPackages/{packageId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Reports
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
    }

    // Archived reports — server only
    match /reports_archive/{reportId} {
      allow read, write: if false;
    }

    // Suspension appeals
    match /suspensionAppeals/{appealId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Seat requests (legacy top-level — keep for backwards compat)
    match /seatRequests/{requestId} {
      allow read, write: if request.auth != null;
    }

    // Admin tokens
    match /admin_tokens/{tokenId} {
      allow read, write: if false;
    }

    // Admin audit log
    match /admin_audit_log/{logId} {
      allow read, write: if false;
    }

    // Report locks
    match /report_locks/{lockId} {
      allow read, write: if false;
    }
  }
}
