rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: get caller's stable uniqueId from custom claims ───
    // The Express API sets this via admin.auth().setCustomUserClaims()
    // after user creation or sign-in. Client must force-refresh token.
    function callerUniqueId() {
      return request.auth.token.uniqueId;
    }

    // ── Users (keyed by uniqueId, not Firebase UID) ──────────────
    match /users/{uniqueId} {
      // Any authenticated user can read profiles
      allow read: if request.auth != null;
      // Owner can update non-economy fields — verified via firebaseUid field
      allow create: if false; // API only (atomic uniqueId + identity map)
      allow update: if request.auth != null
        && resource.data.firebaseUid == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['shyCoins', 'shyBeans', 'isSuperShy', 'superShyExpiry', 'superShyTier',
                     'gcsLastDeductionAt', 'isSuspended', 'suspensionReason',
                     'suspensionEndDate', 'userType', 'uniqueId', 'firebaseUid', 'providers',
                     'pinHash', 'pinSetAt', 'pinAttempts', 'pinLockedUntil', 'pinLockoutCount',
                     'deletionScheduledAt', 'deletionReason', 'deletionExecuteAt',
                     'dataExportStatus', 'dataExportR2Key', 'dataExportExpiresAt',
                     'lastDataExportRequestedAt',
                     'gcsScore', 'gcs_score', 'gcs_last_deduction_at',
                     'warningCount', 'warning_count', 'hasActiveWarning', 'has_active_warning',
                     'hasNewWarning', 'warningReason', 'warning_reason', 'warningIssuedAt',
                     'suspensionStartDate', 'suspension_start_date', 'suspensionCanAppeal',
                     'suspendedBy', 'is_suspended', 'suspensionReason', 'suspension_reason',
                     'preSuspensionDisplayName', 'preSuspensionProfilePhotoUrl',
                     'preSuspensionCoverPhotoUrl', 'roleChanged',
                     'unique_id', 'firebase_uid',
                     'fcmTokens', 'fcm_tokens']);

      // Backpack — read own, write only via API
      match /backpack/{giftId} {
        allow read: if request.auth != null
          && callerUniqueId() == int(uniqueId);
        allow write: if false;
      }

      // Warnings — server only
      match /warnings/{warningId} {
        allow read: if false;
        allow write: if false;
      }

      // Gift Wall — auth read, write only via API
      match /giftWall/{giftId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // Transactions — owner or admin read, write only via API
      match /transactions/{txId} {
        allow read: if request.auth != null
                    && (callerUniqueId() == int(uniqueId) || request.auth.token.admin == true);
        allow write: if false;
      }

      // Stalkers (profile visitors) — owner reads, visitors create own entry
      match /stalkers/{visitorId} {
        allow read: if request.auth != null
          && callerUniqueId() == int(uniqueId);
        allow create: if request.auth != null
          && string(callerUniqueId()) == visitorId;
        allow update, delete: if false;
      }

      // Private data — server only (TOTP secrets, encrypted keys)
      match /private/{docId} {
        allow read, write: if false;
      }
    }

    // ── Identity Map — auth read, server write only ──────────────
    match /identityMap/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Counters — server only ───────────────────────────────────
    match /counters/{counterId} {
      allow read, write: if false;
    }

    // ── Rooms ────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Update: owner, current participant, or new user joining (adding themselves to participantIds/firstJoinTimestamps only)
      // ownerId and participantIds store String uniqueIds; callerUniqueId() is a Number (custom claim).
      // Cast to string for comparison to avoid silent type-mismatch failures.
      allow update: if request.auth != null
        && (string(callerUniqueId()) == resource.data.ownerId
            || string(callerUniqueId()) in resource.data.participantIds
            || (request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['participantIds', 'firstJoinTimestamps'])
                && string(callerUniqueId()) in request.resource.data.participantIds));
      // Delete: only owner
      allow delete: if request.auth != null
        && string(callerUniqueId()) == resource.data.ownerId;

      // Room chat messages
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null
          && string(callerUniqueId()) == resource.data.senderId;
      }

      // Seat requests — owner can approve/deny, requester can cancel own
      match /seatRequests/{requestId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null
          && (string(callerUniqueId()) == get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId
              || string(callerUniqueId()) == resource.data.userId);
      }
    }

    // ── Conversations ────────────────────────────────────────────
    match /conversations/{conversationId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null
                  && string(callerUniqueId()) in resource.data.participantIds;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && string(callerUniqueId()) in resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if request.auth != null
          && string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if request.auth != null
          && (string(callerUniqueId()) == resource.data.senderId
              || string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.groupAdminIds
              || string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.groupModIds);

        match /edits/{editId} {
          allow read: if request.auth != null
            && string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
          allow create: if request.auth != null
            && string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
      }

      // User-specific conversation settings — own settings, or participant can init others during group creation
      match /userSettings/{settingsId} {
        allow read: if request.auth != null
          && string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow write: if request.auth != null
          && (string(callerUniqueId()) == settingsId
              || string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.groupAdminIds);
      }

      // Legacy settings path
      match /settings/{settingsId} {
        allow read, write: if request.auth != null
          && string(callerUniqueId()) == settingsId;
      }

      // Mutes — participants read, admins/mods can mute/unmute members
      match /mutes/{muteId} {
        allow read: if request.auth != null
          && string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow write: if request.auth != null
          && (string(callerUniqueId()) == muteId
              || string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.groupAdminIds
              || string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.groupModIds);
      }

      // Mod log — participants read, admins/mods create
      match /mod_log/{logId} {
        allow read: if request.auth != null
          && string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if request.auth != null
          && (string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.groupAdminIds
              || string(callerUniqueId()) in get(/databases/$(database)/documents/conversations/$(conversationId)).data.groupModIds);
      }
    }

    // ── App config — auth read, server write ─────────────────────
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Device bindings — auth read own, API creates ─────────────
    // Client writes "userId" field, API writes "uniqueId" — accept either
    match /deviceBindings/{deviceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && (request.resource.data.userId == string(callerUniqueId())
            || request.resource.data.uniqueId == string(callerUniqueId()));
      allow update: if request.auth != null
        && (resource.data.userId == string(callerUniqueId())
            || resource.data.uniqueId == string(callerUniqueId()));
      allow delete: if false;
    }

    // ── Gift catalog — auth read, server write ───────────────────
    match /gifts/{giftId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Gift rankings — auth read, server write ──────────────────
    match /giftRankings/{giftId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Broadcasts — auth read, server write ─────────────────────
    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Coin packages — auth read, server write ──────────────────
    match /coinPackages/{packageId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Reports — admin reads, server writes ─────────────────────
    match /reports/{reportId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow create: if false;
      allow update: if false;
    }

    // ── Archived reports — server only ───────────────────────────
    match /reportsArchive/{reportId} {
      allow read, write: if false;
    }

    // ── Suspension appeals ───────────────────────────────────────
    match /suspensionAppeals/{appealId} {
      allow read: if request.auth != null
        && resource.data.uniqueId == string(callerUniqueId());
      allow create: if request.auth != null;
    }

    // ── Fun facts — auth read, server write ──────────────────────
    match /funFacts/{factId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Banners — auth read, server write ────────────────────────
    match /banners/{bannerId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Admin tokens — server only ───────────────────────────────
    match /adminTokens/{tokenId} {
      allow read, write: if false;
    }

    // ── Admin audit log — admin read, server write ───────────────
    match /adminAuditLog/{logId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── Report locks — server only ───────────────────────────────
    match /reportLocks/{lockId} {
      allow read, write: if false;
    }

    // ── Logs — admin reads, server writes ────────────────────────
    match /logs/{logId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── Log config — any auth read, server write ─────────────────
    match /logConfig/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Log stats — any auth read, server write ──────────────────
    match /logStats/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Device bans — admin read, server write ───────────────────
    match /deviceBans/{deviceId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── Network bans — admin read, server write ──────────────────
    match /networkBans/{banId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── Alerts — admin read, server write ────────────────────────
    match /alerts/{alertId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── Alert config — admin read, server write ──────────────────
    match /alertConfig/{docId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── OTP codes — server-only (Admin SDK bypasses rules) ──────
    match /otpCodes/{email} {
      allow read, write: if false;
    }

    // ── TOTP recovery codes — server-only ──────────────────────
    match /totpRecoveryCodes/{email} {
      allow read, write: if false;
    }

    // ── Biometric keys — server-only ────────────────────────────
    match /biometricKeys/{keyId} {
      allow read, write: if false;
    }

    // ── Email metrics — server-only ─────────────────────────────
    match /emailMetrics/{docId} {
      allow read, write: if false;
    }

    // ── Purchase receipts — server-only (IAP dedup) ─────────────
    match /purchaseReceipts/{receiptId} {
      allow read, write: if false;
    }

    // ── Suggestions — public read (non-pending), auth create ────
    match /suggestions/{suggestionId} {
      allow read: if resource.data.status != 'pending'
                  || (request.auth != null && string(callerUniqueId()) == resource.data.submitterUid)
                  || (request.auth != null && request.auth.token.admin == true);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (string(callerUniqueId()) == resource.data.submitterUid && resource.data.status == 'pending')
                    || (request.auth != null && request.auth.token.admin == true);
      allow delete: if request.auth != null
                    && string(callerUniqueId()) == resource.data.submitterUid
                    && resource.data.status == 'pending';

      match /votes/{voteId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.voterId == string(callerUniqueId());
        allow update: if request.auth != null
                      && resource.data.voterId == string(callerUniqueId());
        allow delete: if request.auth != null
                      && resource.data.voterId == string(callerUniqueId());
      }

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if false;
      }
    }

    // ── Blocked topics — admin write, public read ───────────────
    match /blockedTopics/{topicId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Suggestion disputes — submitter create, admin resolve ───
    match /suggestionDisputes/{disputeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Subscriptions — owner-only read/write ───────────────────
    match /subscriptions/{uid} {
      allow read, write: if request.auth != null && string(callerUniqueId()) == uid;
    }

    // ── Notifications — owner read/update, server create ────────
    match /notifications/{notifId} {
      allow read: if request.auth != null
                  && resource.data.uid == string(callerUniqueId());
      allow update: if request.auth != null
                    && resource.data.uid == string(callerUniqueId());
      allow create, delete: if false;
    }

    // ── Identity graphs — admin-only ────────────────────────────
    match /identityGraphs/{graphId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Notification queue — server-only ────────────────────────
    match /notificationQueue/{docId} {
      allow read, write: if false;
    }

    // ── Audit log — admin read, server write ──────────────────
    match /auditLog/{logId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ── Moderation log — admin read, server write ─────────────
    match /moderationLog/{logId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }
  }
}
